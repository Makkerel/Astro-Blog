---
import BaseLayout from "../layouts/baseLayout.astro";
import Link from "../components/link.astro";
import Blogpost from "../components/blogpost.astro";
import FindMe from "../components/findMe.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import "../styles/global.css";

const all_posts = Object.values(
    import.meta.glob("./posts/*.mdx", { eager: true }),
);
const page_title = "Welcome";

const stick_figures = import.meta.glob<{ default: ImageMetadata }>(
    "../assets/stick_figures/*.png",
);

const stick_images = Object.values(stick_figures);

all_posts.sort((a: any, b: any) => {
    if (a.frontmatter.date < b.frontmatter.date) {
        return 1;
    }
    if (a.frontmatter.date > b.frontmatter.date) {
        return -1;
    }
    return 0;
});
---

<style>
    .intro_paragraph {
        display: flex;
        place-items: center;
    }

    .intro_p {
        flex: 2;
        min-width: 0;
    }

    .intro_img {
        text-align: center;
        flex: 1;
        min-width: 300px;
    }

    #img_container {
        display: grid;
        justify-content: center;
        grid-template-areas: "stack";
        cursor: pointer;
        margin: 0 auto;
    }

    .img_list {
        grid-area: stack;
        opacity: 0;
        transition: opacity 0.4s ease-in-out;
        pointer-events: none;
    }

    .img_list.active {
        opacity: 1;
        pointer-events: auto;
    }

    .page-header {
        display: grid;
    }

    .page-header h2 {
        grid-area: 1 / 1;
    }

    .section-link {
        grid-area: 1 / 1;
        justify-self: end;
        align-self: center;
        margin: 0;
        padding: 0 1rem 0 1rem;
    }

    .section-link a {
        color: var(--accent-color);
        white-space: nowrap;
    }

    .section-link a:hover {
        filter: brightness(150%);
    }

    @media (max-width: 768px) {
        .intro_paragraph {
            flex-direction: column;
        }

        .intro_img {
            margin: 0 auto;
        }
    }

    @media (max-width: 450px) {
        .section-link {
            justify-self: start;
            grid-area: 2 / 1;
        }
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        const image_container = document.getElementById("img_container");
        if (!image_container) {
            return;
        }
        const images = document.querySelectorAll(".img_list");
        let currentIndex = 0;
        image_container.addEventListener("click", () => {
            let nextIndex;
            do {
                nextIndex = Math.floor(Math.random() * images.length);
            } while (nextIndex === currentIndex);
            images[currentIndex].classList.remove("active");
            images[nextIndex].classList.add("active");
            currentIndex = nextIndex;
        });
    });
</script>

<BaseLayout page_title={page_title}>
    <h1>Welcome!</h1>
    <div class="intro_paragraph">
        <div class="intro_p">
            <p>
                Hi I'm Kevin and this website serves as the corner of the
                internet where I put my stuff. I'm currently a student at UCSB
                studying computer science with a minor in math.
            </p>
        </div>
        <div class="intro_img">
            Click Me!
            <div id="img_container">
                <Image
                    src={stick_images[0]()}
                    alt="begin_image"
                    class="img_list active"
                    width={300}
                />
                {
                    stick_images
                        .slice(1)
                        .map((image) => (
                            <Image
                                src={image()}
                                alt="stick man"
                                class="img_list"
                                width={300}
                            />
                        ))
                }
            </div>
        </div>
    </div>

    <h2>What To Expect Here</h2>
    <p>
        Most of the stuff here is text but I'm learning to draw so hopefully I
        have some artwork here soon. Alongside artwork I also plan to add a
        projects tab for some stuff I've built but for now I'm working on making
        blogs and improving the blogs over time so that they're fun to read.
    </p>
    <p>
        You can lean more about the website itself by going to the <Link
            link="/collophon"
            name="collophon"
        /> and if you want to know more about me go the <Link
            link="/about"
            name="about"
        /> page. Final note links with an arrow are external links and anything without
        the arrow are internal links.
    </p>
    <h2>Find Me</h2>
    <FindMe />
    <div class="page-header">
        <h2>Recent Blogs</h2>
        <p class="section-link">
            <a href="/blogs/">View all posts →</a>
        </p>
    </div>
    {
        all_posts
            .slice(0, 3)
            .map((post: any) => (
                <Blogpost
                    url={post.url}
                    title={post.frontmatter.title}
                    date={post.frontmatter.date}
                    description={post.frontmatter.description}
                />
            ))
    }
</BaseLayout>
