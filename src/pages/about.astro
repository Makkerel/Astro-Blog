            <br />
            <Link link="https://coolors.co/" name="Coolor Co:" />
            <span> Allows you to generate color schemes</span>
            <br />
            <Link link="https://devhints.io/" name="Dev Hints:" />
            <span> Some useful cheatsheets for devs</span>
        </p>
    </Details>
</BaseLayout>
