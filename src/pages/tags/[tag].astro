---
import BaseLayout from "../../layouts/baseLayout.astro";
import Blogpost from "../../components/blogpost.astro";

export async function getStaticPaths() {
    const all_posts = Object.values(
        import.meta.glob("../posts/*.mdx", { eager: true }),
    );
    const unique_tags = [
        ...new Set(all_posts.map((post: any) => post.frontmatter.tags).flat()),
    ];
    return unique_tags.map((tag) => {
        const filtered_post = all_posts
            .filter((post: any) => post.frontmatter.tags.includes(tag))
            .sort((a: any, b: any) => {
                if (a.frontmatter.date < b.frontmatter.date) return 1;
                if (a.frontmatter.date > b.frontmatter.date) return -1;
                return 0;
            });
        return {
            params: { tag },
            props: { posts: filtered_post },
        };
    });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout page_title={tag}>
    <div class="page-header">
        <p class="page-title"><span class="title-tag">{tag}</span> Posts</p>
        <p class="back-link">
            <a href="/blogs/" id="tag-back-link">← All posts</a>
        </p>
    </div>
    {
        posts.map((post: any) => (
            <Blogpost
                url={post.url}
                title={post.frontmatter.title}
                date={post.frontmatter.date}
                description={post.frontmatter.description}
            />
        ))
    }
</BaseLayout>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .page-title {
        font-size: 1.2rem;
        font-family: var(--font-exo-2);
    }

    .title-tag{
        color: var(--tertiary-color);
    }

    .back-link {
        padding: 0 1rem 0 0;
    }

    .back-link a {
        color: var(--accent-color);
        white-space: nowrap;
    }

    .back-link a:hover {
        filter: brightness(150%);
    }
</style>

<script>
    const postPathPattern = /^\/posts\/[^/]+\/?$/;

    function updateBackLink() {
        const anchor = document.querySelector<HTMLAnchorElement>("#tag-back-link");
        if (!anchor) return;

        const from = new URLSearchParams(location.search).get("from");
        if (from && postPathPattern.test(from)) {
            anchor.href = from;
            anchor.textContent = "← Back to article";
        } else {
            anchor.href = "/blogs/";
            anchor.textContent = "← All posts";
        }
    }

    updateBackLink();
    document.addEventListener("astro:page-load", updateBackLink);
</script>
