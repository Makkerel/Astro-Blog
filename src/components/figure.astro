---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    src: ImageMetadata;
    alt: string;
    caption?: string;
    width?: number;
}

const { src, alt, caption, width = 1000 } = Astro.props;
---

<figure class="figure">
    <Image src={src} alt={alt} layout="constrained" width={width} />
    {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
    .figure {
        margin: 0;
        text-align: center;
    }

    figcaption {
        font-size: 0.85rem;
    }
</style>
