---
const links = [
    {
        name: "Email",
        url: "mailto:kzhao132018@gmail.com",
        description: "kzhao132018@gmail.com",
    },
    {
        name: "Github",
        url: "https://github.com/Makkerel",
        description: "Code & projects",
    },
    {
        name: "LinkedIn",
        url: "https://www.linkedin.com/in/kevin-zhao-955069334",
        description: "Professional",
    },
    {
        name: "Handshake",
        url: "https://ucsb.joinhandshake.com/profiles/xddrqq",
        description: "Campus recruiting",
    },
];
---

<div class="find-me-grid">
    {
        links.map(({ name, url, description }) => (
            <a
                class="find-me-item"
                href={url}
                target={url.startsWith("mailto:") ? undefined : "_blank"}
                rel={
                    url.startsWith("mailto:")
                        ? undefined
                        : "noopener noreferrer"
                }
            >
                <span class="find-me-name">{name}</span>
                <span class="find-me-desc">{description}</span>
            </a>
        ))
    }
</div>

<style>
    .find-me-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .find-me-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1rem;
        border: 1px solid var(--secondary-color);
        transition: filter 0.3s ease;
    }

    .find-me-item:hover {
        filter: brightness(150%);
    }

    .find-me-name {
        font-family: var(--font-exo-2), sans-serif;
        font-size: 1.1rem;
        color: var(--accent-color);
    }

    .find-me-desc {
        color: var(--secondary-color);
        font-size: 0.85rem;
    }

    @media (max-width: 600px) {
        .find-me-grid {
            grid-template-columns: 1fr;
        }

        .find-me-item {
            border-right: none;
            border-left: none;
            border-bottom: 1px solid var(--secondary-color);
        }
    }
</style>
