---
interface Heading {
    depth: number;
    slug: string;
    text: string;
}

interface Props {
    headings: Heading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
    tocHeadings.length > 0 && (
        <aside class="toc">
            <nav aria-label="Table of contents">
                <p class="toc-label">On this page</p>
                <ul class="toc-list">
                    {tocHeadings.map((heading) => (
                        <li
                            class:list={[
                                "toc-item",
                                heading.depth === 3 && "toc-item-nested",
                            ]}
                        >
                            <a href={`#${heading.slug}`}>{heading.text}</a>
                        </li>
                    ))}
                </ul>
                <a href="#" class="toc-back">Back to top</a>
            </nav>
        </aside>
    )
}

<style>
    .toc {
        display: none;
        font-size: 0.85rem;
        line-height: 1.4;
    }

    .toc-label {
        font-weight: bold;
        font-size: 0.9rem;
        margin: 0 0 0.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--secondary-color);
    }

    .toc-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .toc-item {
        padding: 0.25rem 0;
    }

    .toc-item-nested {
        padding-left: 0.75rem;
        font-size: 0.95em;
        opacity: 90%;
    }

    .toc-item a {
        display: block;
        border-left: 2px solid transparent;
        padding-left: 0.25rem;
    }

    .toc-item a,
    .toc-back {
        color: var(--secondary-color);
        transition: color 0.2s ease, border-color 0.2s ease;
    }

    .toc-item a:hover,
    .toc-back:hover {
        color: var(--accent-color);
    }

    .toc-item a.active {
        border-left-color: var(--accent-color);
    }

    .toc-back {
        text-align: center;
        display: block;
        margin-top: 0.75rem;
        padding-top: 0.5rem;
        border-top: 1px solid var(--secondary-color);
    }

    @media (min-width: 1400px) {
        .toc {
            display: block;
            position: fixed;
            top: 6rem;
            left: calc((100vw + 1000px) / 2 + 1rem);
            width: 180px;
            max-height: calc(100vh - 7rem);
            overflow-y: auto;
        }
    }
</style>

<script>
    const HEADER_OFFSET = 100;
    const CLICK_LOCK_MS = 500;
    const BOTTOM_OFFSET = 120;

    let cleanup: (() => void) | null = null;

    function initTocSpy() {
        cleanup?.();

        const toc = document.querySelector(".toc");
        if (!toc) {
            cleanup = null;
            return;
        }

        const links = toc.querySelectorAll<HTMLAnchorElement>(".toc-item a");
        if (!links.length) {
            cleanup = null;
            return;
        }

        const headings = [...links]
            .map((link) => {
                const id = link.getAttribute("href")?.slice(1);
                return id ? document.getElementById(id) : null;
            })
            .filter((heading): heading is HTMLElement => heading !== null);

        if (!headings.length) {
            cleanup = null;
            return;
        }

        let activeId = "";
        let clickLock = false;
        let clickLockTimer: ReturnType<typeof setTimeout> | undefined;

        function setActive(id: string | null) {
            if (id === activeId) return;
            activeId = id ?? "";

            for (const link of links) {
                const isActive =
                    id !== null && link.getAttribute("href") === `#${id}`;
                link.classList.toggle("active", isActive);
                if (isActive) {
                    link.setAttribute("aria-current", "location");
                } else {
                    link.removeAttribute("aria-current");
                }
            }
        }

        function atPageBottom() {
            return (
                window.innerHeight + window.scrollY >=
                document.documentElement.scrollHeight - BOTTOM_OFFSET
            );
        }

        function updateActive() {
            if (clickLock) return;

            if (atPageBottom()) {
                setActive(headings[headings.length - 1].id);
                return;
            }

            let current: HTMLElement | null = null;
            for (const heading of headings) {
                if (heading.getBoundingClientRect().top <= HEADER_OFFSET) {
                    current = heading;
                }
            }

            setActive(current?.id ?? null);
        }

        function onTocClick(event: Event) {
            const link = (event.target as Element).closest(".toc-item a");
            if (!link) return;

            const id = link.getAttribute("href")?.slice(1);
            if (!id) return;

            clickLock = true;
            clearTimeout(clickLockTimer);
            setActive(id);
            clickLockTimer = setTimeout(() => {
                clickLock = false;
                updateActive();
            }, CLICK_LOCK_MS);
        }

        toc.addEventListener("click", onTocClick);
        window.addEventListener("scroll", updateActive, { passive: true });
        updateActive();

        cleanup = () => {
            toc.removeEventListener("click", onTocClick);
            window.removeEventListener("scroll", updateActive);
            clearTimeout(clickLockTimer);
            setActive(null);
        };
    }

    document.addEventListener("astro:page-load", initTocSpy);
    initTocSpy();
</script>
