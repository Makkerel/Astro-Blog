---
interface Props {
    tags: string[];
}

const { tags } = Astro.props;
---

{
    tags.length > 0 && (
        <footer class="post-tags">
            <h3>Tags</h3>
            <div class="tags">
                {tags.map((tag) => (
                    <a href="/blogs" class="tag">
                        {tag}
                    </a>
                ))}
            </div>
        </footer>
    )
}

<style>
    .post-tags {
        margin-top: 1.5rem;
    }

    .tags {
        display: flex;
        padding: 1rem;
        gap: 1rem;
    }

    .tag {
        font-size: 150%;
        padding: 0.5rem;
        border: 1px solid var(--secondary-color);
        transition: filter 0.3s ease;
    }

    .tag:hover {
        filter: brightness(150%);
    }
</style>
