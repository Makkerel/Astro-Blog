---
interface Props {
    tags: string[];
    heading?: boolean;
    returnTo?: string;
}

const { tags, heading = true, returnTo: returnToProp } = Astro.props;

const returnTo =
    returnToProp ??
    (Astro.url.pathname.startsWith("/posts/")
        ? Astro.url.pathname
        : undefined);

function tagHref(tag: string) {
    const base = `/tags/${encodeURIComponent(tag)}/`;
    return returnTo
        ? `${base}?from=${encodeURIComponent(returnTo)}`
        : base;
}
---

{
    tags.length > 0 && (
        <>
            {heading && <h3>Tags</h3>}
            <div class="tags">
                {tags.map((tag) => (
                    <a href={tagHref(tag)} class="tag">
                        {tag}
                    </a>
                ))}
            </div>
        </>
    )
}

<style>
    .tags {
        display: flex;
        flex-wrap: wrap;
        padding: 1rem;
        gap: 1rem;
    }

    .tag {
        font-size: 125%;
        font-family: var(--font-atkinson);
        padding: 0.25rem 0.75rem;
        border: 1px solid var(--secondary-color);
        transition: filter 0.3s ease;
    }

    .tag:hover {
        filter: brightness(150%);
    }
</style>
