---
import { Diamond } from "@lucide/astro";
import Link from "./link.astro";

export interface ListItem {
    name: string;
    link: string;
    description: string;
}

interface Props {
    items: ListItem[];
}

const { items } = Astro.props;
---

<ul class="link-list">
    {
        items.map(({ name, link, description }) => (
            <li class="link-list-item">
                <Diamond
                    size={12}
                    class="link-list-marker"
                    aria-hidden="true"
                />
                <span class="link-list-content">
                    <Link {link} {name} />
                    <span class="link-list-desc"> - {description}</span>
                </span>
            </li>
        ))
    }
</ul>

<style>
    .link-list {
        list-style: none;
        margin: 0 1rem;
        padding: 1rem 0;
    }

    .link-list-desc {
        font-family: var(--font-atkinson), sans-serif;
    }

    .link-list-item {
        display: flex;
        gap: 0.5rem;
    }

    .link-list-marker {
        flex-shrink: 0;
        margin-top: 0.5rem;
        color: var(--tertiary-color);
    }
</style>
