---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    title: string;
    image: ImageMetadata;
    alt: string;
}

const { title, image, alt } = Astro.props;
---

<section class="now-section">
    <div class="now-section-content">
        <h2>{title}</h2>
        <div class="now-section-image-wrap">
            <Image src={image} alt={alt} width={1000} class="now-section-image" />
        </div>
        <slot />
    </div>
</section>
