---
import BaseLayout from "./baseLayout.astro";
import "../styles/global.css";
const { frontmatter } = Astro.props;
---

<style>
    :global(pre) {
        margin: 1rem;
    }

    .tags {
        display: flex;
        padding: 1rem;
        gap: 1rem;
    }

    .tag {
        font-size: 150%;
        padding: 0.5rem;
        border: 1px solid var(--secondary-color);
        transition: filter 0.3s ease;
    }

    .tag:hover {
        filter: brightness(150%);
    }
</style>

<BaseLayout page_title={frontmatter.title}>
    <slot />
    <h3>Tags</h3>
    <div class="tags">
        {
            frontmatter.tags.map((tag: string) => (
                <a href="/blogs" class="tag">
                    {tag}
                </a>
            ))
        }
    </div>
</BaseLayout>
